# ============================================================
# .env.example — copy this to .env and fill in your values
# Usage:  cp .env.example .env
# ============================================================

# ── API Keys ────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Twitter/X — optional. Leave blank to disable social media collection.
TWITTER_BEARER_TOKEN=

# OpenAI — optional. Used by Agent 1 for NLP enrichment of social posts.
# Leave blank to skip LLM enrichment (system still works without it).
OPENAI_API_KEY=

# ── Google Earth Engine ─────────────────────────────────────
# GEE project ID (create at console.cloud.google.com)
GEE_PROJECT_ID=your_gee_project_id

# Path to your earthengine credentials directory ON THE HOST MACHINE.
# Docker will mount this into the container automatically.
#
# Linux / Mac:
#   GEE_CREDENTIALS_DIR=~/.config/earthengine
# Windows (use forward slashes or escape backslashes):
#   GEE_CREDENTIALS_DIR=C:/Users/YourName/.config/earthengine
#
# Authenticate once on your host with:  earthengine authenticate
GEE_CREDENTIALS_DIR=~/.config/earthengine

# ── Agent 1 Model ───────────────────────────────────────────
# Path INSIDE the container — do not change unless you move the model file
FLOOD_MODEL_PATH=/app/backend/models/flood_fast_best.keras
SAR_REF_START=2024-01-01
SAR_REF_END=2024-04-06

# ── Agent Settings ──────────────────────────────────────────
AGENT_ID=agent_1_environmental
MONITORING_INTERVAL=300
ENABLE_ADAPTIVE_POLLING=true
ENABLE_TWITTER_MONITORING=false

# RUNTIME_MODE controls whether agents use live APIs or replay scenario data.
# Options: simulation | live
RUNTIME_MODE=simulation

LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────
# These are used inside Docker — do not change the hostnames
POSTGRES_DB=disaster_response
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/disaster_response
DATABASE_URL_ASYNC=postgresql://postgres:postgres@postgres:5432/disaster_response

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Routing ─────────────────────────────────────────────────
# Public OSRM server — Agent 4 falls back to Haversine if this is unavailable
OSRM_URL=http://router.project-osrm.org

# ── Mock Publisher (offline dev) ────────────────────────────
# Used when running:  docker-compose --profile mock up
# Options: mirpur_flood | sylhet_flood | multi_zone | all
MOCK_SCENARIO=multi_zone
